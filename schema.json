{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Shipmate Configuration",
  "description": "Configuration schema for shipmate plugin",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Paths to skill directories"
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Paths to agent directories"
    },
    "agentOverrides": {
      "type": "object",
      "description": "Per-agent configuration overrides",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "model": {
            "type": "string",
            "description": "Model ID or 'inherit' from parent session"
          },
          "temperature": {
            "type": "number",
            "minimum": 0,
            "maximum": 2,
            "description": "Sampling temperature"
          },
          "top_p": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Nucleus sampling parameter"
          },
          "prompt": {
            "type": "string",
            "description": "Override system prompt"
          },
          "promptAppend": {
            "type": "string",
            "description": "Append to system prompt"
          },
          "disable": {
            "type": "boolean",
            "description": "Disable this agent"
          }
        }
      }
    }
  },
  "required": ["skills", "agents"]
}
