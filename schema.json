{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Shipmate Configuration",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "skills": {
      "type": "object",
      "properties": {
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "recursive": { "type": "boolean", "default": true },
              "glob": { "type": "string" }
            },
            "required": ["path"]
          }
        },
        "enable": {
          "type": "array",
          "items": { "type": "string" }
        },
        "disable": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "agents": {
      "type": "object",
      "properties": {
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" }
            },
            "required": ["path"]
          }
        }
      }
    }
  }
}
